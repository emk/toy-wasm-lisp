// The original WASI 0.1 interface, while it was
// still really simple.
import wasi_snapshot_preview1 {
    // Write I/O vecs.
    func fd_write(
        fd: i32,
        ciovs_ptr: *record {
            buf: *u8,
            buf_len: u32,
        },
        ciovs_len: u32,
        nwritten_out_ptr: *mut u32,
    ) -> u32;

    // Exit the process (e.g., on fatal error).
    func proc_exit(exitcode: u32);
}

// EXPECT: f() == 0
